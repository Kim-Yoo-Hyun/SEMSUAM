  "utility_design_constraints": {
    "utility_name": "candidate_relative_active_observation_utility_v1",
    "utility_is_not": "goal_correctness_probability",
    "utility_terms": [
      {
        "name": "RivalAmbiguity",
        "source": "candidate_relative_unique_top, tie_or_saturation, weak_or_partial support, and gap-to-best-rival fields",
        "intended_effect": "prioritize rows where map/pose support separates candidates but prior task join showed that the separation can still be wrong."
      },
      {
        "name": "PoseContextGap",
        "source": "strict edge variant readiness and largest-component fractions excluding candidate-overlap-only shortcuts",
        "intended_effect": "prioritize views that can add spatial, loop, or target-context edges instead of only reusing same-candidate overlap."
      },
      {
        "name": "ProjectionUncertainty",
        "source": "projection visible fraction, entropy, axis failure diversity, and visible heading gaps",
        "intended_effect": "prioritize candidates whose current evidence is viewpoint-conditioned and likely under-observed."
      },
      {
        "name": "SaturationRisk",
        "source": "all-candidates-ready and multi-candidate-all-ready request state",
        "intended_effect": "prevent all-ready geometry saturation from becoming a commit rule."
      },
      {
        "name": "ObservationCostProxy",
        "source": "target distance from viewpoint and physical viewpoint readiness",
        "intended_effect": "keep the utility motion-aware without using shortest-path oracle labels."
      }
    ],
    "required_request_policy": [
      "candidate_relative_unique_top_nonterminal rows may rank the top map/pose candidate and strongest rival for observation, but may not commit the top candidate.",
      "candidate_relative_tie_or_saturation_nonterminal rows must be treated as ambiguity rows; they may request pair/context observation or defer.",
      "single_candidate_geometry_only_nonterminal rows may request lightweight confirmation but may not become terminal commits without later non-GT goal-validity evidence.",
      "candidate-overlap-only request rows must receive a context-gap risk tag because candidate overlap alone is not pose/context support.",
      "no-valid and wrong-goal labels may be joined only after action rows are frozen and only as evaluation-only diagnostics."
    ]
  },
