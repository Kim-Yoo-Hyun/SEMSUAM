    "name": "relation_depth_guarded_non_gt_arbitration_v1",
    "purpose": "Reject relation-depth-resolved candidates when the same candidate lacks independent candidate-specific support in the full candidate-specific substrate.",
    "non_gt_action_features": [
      "relation_depth_recheck_status",
      "relation_direction_source_coverage",
