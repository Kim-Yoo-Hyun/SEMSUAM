      },
      {
        "if": "relation_depth_recheck_status == relation_depth_recheck_resolved and base_candidate_association != true",
        "then": "reject_relation_depth_resolved_without_base_detector_association"
      },
      {
        "if": "relation_depth_recheck_status == relation_depth_recheck_resolved and base_consistent_depth_count < 1",
        "then": "reject_relation_depth_resolved_without_base_depth_consistency"
      },
      {
        "if": "more_than_one_candidate_satisfies_candidate_specific_support_and_base_association",
        "then": "defer_support_saturation_no_unique_goal_identity"
      },
      {
        "if": "exactly_one_candidate_satisfies_all_non_gt_gates",
        "then": "provisional_unique_goal_validity_candidate_requires_fresh_validation"
      }
    ],
