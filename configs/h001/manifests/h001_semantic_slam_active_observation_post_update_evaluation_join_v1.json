  "uncertainty_decomposition_schema": {
    "goal_validity_risk": {
      "role": "task-level risk surface for Semantic-SLAM uncertainty",
      "action_time_inputs_allowed": [
        "selected_observation_action",
        "selected_candidate_ids",
        "pre_update_request_risk_tags",
        "post_update_request_state",
        "post_observation_state",
        "request_evidence_delta",
        "evidence_delta"
      ],
      "evaluation_only_inputs_after_freeze": [
        "candidate_correctness_label",
        "candidate_wrong_label",
        "correct_candidate_count",
        "wrong_candidate_count",
        "no_valid_candidate_pool",
        "wrong_goal_visit_proxy",
        "no_valid_commit_proxy"
      ],
      "required_output_fields": [
        "goal_validity_risk_state",
        "goal_validity_risk_proxy",
        "goal_validity_label_join_available",
        "selected_candidate_clean_correct_count",
        "selected_candidate_wrong_or_no_valid_count",
        "wrong_goal_visit_proxy",
        "no_valid_pool_proxy"
      ],
      "usage_rule": "Goal-validity labels are evaluation-only and may not repair, rerank, commit, or reject candidates."
    },
    "viewpoint_evidence_gap": {
      "role": "reason the robot moved before terminal commitment",
      "action_time_inputs_allowed": [
        "selected_observation_action",
        "selected_candidate_count",
        "selected_candidate_ids",
        "observation_evidence",
        "evidence_delta",
        "evidence_delta_available",
        "post_observation_state",
        "selected_candidate_utility_scores",
        "utility_terms",
        "risk_tags",
        "target_distance_mean_m",
        "projection_visible_fraction"
      ],
      "required_output_fields": [
        "viewpoint_evidence_gap_state",
        "viewpoint_evidence_gap_proxy",
        "selected_observation_action",
        "selected_candidate_count",
        "evidence_delta_available",
        "reobserve_travel_cost_m"
      ],
      "usage_rule": "The gap may justify evidence acquisition or deferral, but it cannot become a direct target-validity proof."
    },
    "map_pose_consistency_uncertainty": {
      "role": "Semantic-SLAM-centered map-side uncertainty tied to the same request/candidate rows",
      "action_time_inputs_allowed": [
        "pose_graph_proxy_ready",
        "strict_edge_variant_proxy_ready",
        "strict_pose_spatial_or_loop_request_ready",
        "strict_pose_loop_request_ready",
        "strict_context_request_ready",
        "pose_graph_connected_component_count",
        "pose_graph_largest_component_fraction",
        "pose_graph_edge_reason_counts",
        "map_pose_score_tuple_rank",
        "map_pose_score_tuple_tie_count",
        "projection_visible_heading_rank",
        "pose_heading_rank"
      ],
      "analysis_only_inputs_after_freeze": [
        "pose_graph_connectivity_delta",
        "map_pose_consistency_delta",
        "map_side_delta",
        "map_task_alignment"
      ],
      "required_output_fields": [
        "map_pose_consistency_uncertainty_state",
        "map_pose_consistency_uncertainty_proxy",
        "pose_graph_connectivity_delta",
        "map_pose_consistency_delta",
        "map_side_delta",
        "map_task_alignment"
      ],
      "usage_rule": "Map/pose evidence is a Semantic-SLAM measurement axis and may not be reduced to candidate-overlap-only shortcut evidence."
    }
  },
  "metric_definitions": {
    "wrong_goal_visit": {
      "primary_definition": "commit-based evaluation-only proxy. A wrong-goal visit is counted only when a frozen policy or proxy commits to a selected candidate that joins to a wrong candidate label.",
      "excluded_from_primary": [
        "near-candidate pass-through without explicit stop/commit",
        "candidate visibility without terminal intent",
        "post_update state support_acquired without commit"
      ],
      "required_fields": [
        "wrong_goal_visit_proxy",
        "wrong_goal_visit_proxy_delta_vs_no_reobserve",
        "wrong_goal_visit_proxy_delta_vs_semantic_only"
      ]
    },
    "wasted_path": {
      "primary_definition": "evaluation-only path-cost proxy that charges re-observation travel cost and wrong/no-valid commit path cost after actions are frozen.",
      "required_fields": [
        "wasted_path_proxy_m",
        "wasted_path_proxy_delta_vs_no_reobserve_m",
        "wasted_path_proxy_delta_vs_semantic_only_m",
        "reobserve_travel_cost_m"
      ]
    },
    "map_pose_consistency": {
      "primary_definition": "map-side delta from pose graph connectivity and candidate-relative map/pose evidence on the same request/candidate rows.",
      "required_fields": [
        "pose_graph_connectivity_delta",
        "map_pose_consistency_delta",
        "map_side_delta",
        "map_task_alignment"
      ]
    }
  },
