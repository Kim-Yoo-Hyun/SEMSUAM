  "evidence_definitions": {
    "view_own_view_support": "A recheck view has candidate-centered own-view support when has_candidate_association is true and at least one association row is projected inside the SAM2 mask.",
    "candidate_own_view_support_acquired": "A target candidate has at least three of four candidate-centered recheck views with view_own_view_support and at least one depth-consistent associated heading across the recheck views.",
    "candidate_own_view_support_partial": "A target candidate has detector boxes and SAM2 masks but fewer than three candidate-associated own-view recheck views or zero depth-consistent associated headings.",
    "candidate_own_view_support_absent": "A target candidate has zero candidate-associated own-view recheck views. This is an audit state, not a rejection rule.",
    "negative_missing_support_guard_ready": "The prior missing-strong-own-view condition is no longer the direct blocker because candidate_own_view_support_acquired is true. This only enables a later guard/arbitration analysis and does not reject or commit candidates.",
    "promotable_branch_outcome": "A request can only be marked promotable-for-next-contract if all target candidates have explicit own-view evidence status, no action labels were used, terminal commits are zero, and the analyzer separates acquired support from ObjectNav goal validity. This outcome permits only a later terminal-utility contract discussion."
  },
