  "design_principle": {
    "fact": "The prior fixed SemanticSLAM score was a midpoint between SemanticOnly and SLAMOnly utilities.",
    "agent_inference": "A valid redesign must express interaction between semantic uncertainty and map/pose uncertainty, not a scalar interpolation between component utilities.",
    "paper_claim": "A proxy redesign can only become paper evidence after later task/map outcome validation; this contract alone is not a contribution claim."
  },
  "policy_definitions": [
    {
      "policy_name": "NoReobserveReference",
      "role": "non_active_reference",
      "utility_formula": "U = 0",
      "allowed_action_inputs": [
        "request group identity",
        "source artifact group",
        "pre-existing proxy rows"
      ],
      "forbidden_action_inputs": [
        "candidate correctness",
        "GT pose error",
        "ObjectNav success or wrong-goal labels"
      ]
    },
    {
      "policy_name": "SemanticOnly",
      "role": "semantic_component_reference",
      "semantic_score_formula": "0.6 * semantic_family_weight + 0.4 * min(candidate_id_count / 10, 1)",
      "travel_penalty_formula": "0.1 * normalized_travel_cost_proxy",
      "utility_formula": "U_sem = semantic_score - travel_penalty",
      "allowed_action_inputs": [
        "semantic_uncertainty_family",
        "candidate_id_count",
        "candidate_set_rule_counts",
        "view_role_counts",
        "viewpoint_source_counts",
        "travel_cost_proxy_m"
      ],
      "forbidden_action_inputs": [
        "strict pose graph connectivity metrics",
        "candidate correctness",
        "GT pose error",
        "ObjectNav success or wrong-goal labels"
      ]
    },
    {
      "policy_name": "SLAMOnly",
      "role": "pose_map_component_reference",
      "slam_gap_formula": "0.5 * (1 - largest_component_fraction) + 0.3 * loop_missing_indicator + 0.2 * edge_sparsity_proxy",
      "travel_penalty_formula": "0.1 * normalized_travel_cost_proxy",
      "utility_formula": "U_slam = slam_gap_score - travel_penalty",
      "allowed_action_inputs": [
        "pose_spatial_or_loop connected_component_count",
        "pose_spatial_or_loop largest_component_fraction",
        "pose_spatial_or_loop edge_count",
        "pose_loop edge_count",
        "map_pose_context_no_candidate edge_count",
        "travel_cost_proxy_m"
      ],
      "forbidden_action_inputs": [
        "semantic_uncertainty_family as a utility term",
        "candidate_id_overlap edges",
        "candidate correctness",
        "GT pose error",
        "ObjectNav success or wrong-goal labels"
      ]
    },
    {
      "policy_name": "SemanticSLAMInteraction",
      "role": "non_dominated_interaction_proxy",
      "semantic_score_formula": "0.6 * semantic_family_weight + 0.4 * min(candidate_id_count / 10, 1)",
      "slam_gap_formula": "0.5 * (1 - largest_component_fraction) + 0.3 * loop_missing_indicator + 0.2 * edge_sparsity_proxy",
      "semantic_pressure_formula": "clip((semantic_score - 0.55) / 0.35, 0, 1)",
      "map_pose_pressure_formula": "clip(slam_gap_score / 0.8, 0, 1)",
      "interaction_formula": "semantic_pressure * map_pose_pressure",
      "travel_penalty_formula": "0.1 * normalized_travel_cost_proxy",
      "utility_formula": "U_interaction = semantic_score - travel_penalty + 0.35 * interaction_formula * slam_gap_score + 0.10 * loop_missing_indicator * semantic_pressure",
      "design_intent": "SLAM gain changes priority only when semantic uncertainty pressure and map/pose gap are both present. This is not a midpoint, component max, or label-tuned interpolation.",
      "allowed_action_inputs": [
        "all SemanticOnly allowed inputs",
        "all SLAMOnly allowed inputs",
        "semantic_pressure derived before evaluation labels",
        "map_pose_pressure derived before evaluation labels"
      ],
      "forbidden_action_inputs": [
        "candidate_id_overlap edges as pose evidence",
        "candidate correctness",
        "GT pose error",
        "ObjectNav success or wrong-goal labels",
        "weights tuned on evaluation labels",
        "post-hoc component winner labels"
      ]
    }
  ],
  "forbidden_redesign_patterns": [
    {
      "pattern": "midpoint_or_linear_interpolation_only",
      "examples": [
        "0.5 * U_sem + 0.5 * U_slam",
        "alpha * U_sem + (1 - alpha) * U_slam without an interaction, constraint, or outcome-linked term"
      ],
      "reason": "It is structurally dominated by the better component under score-only ranking."
    },
    {
      "pattern": "component_max_shortcut",
      "examples": [
        "max(U_sem, U_slam)",
        "choose SemanticOnly or SLAMOnly after seeing which component wins"
      ],
      "reason": "It is an oracle-style policy selection shortcut, not SemanticSLAM complementarity."
    },
    {
      "pattern": "constant_bonus_scale_trick",
      "examples": [
        "U_sem + constant",
        "U_sem + epsilon * U_slam without a semantic-map interaction gate"
      ],
      "reason": "It can create rank-1 rows without explaining a failure mechanism."
    },
    {
      "pattern": "label_tuned_weight_search",
      "examples": [
        "grid search alpha on wrong-goal labels",
        "select weights on Success Rate or SPL"
      ],
      "reason": "It leaks evaluation objectives into action evidence and weakens reviewer defense."
    }
  ],
