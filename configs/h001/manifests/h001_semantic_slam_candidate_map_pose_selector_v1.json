  "failure_taxonomy": [
    {
      "tag": "no_candidate_map_pose_ready",
      "meaning": "No candidate has enough candidate-specific frame, pose, depth, projection, and navmesh evidence."
    },
    {
      "tag": "multiple_map_pose_ready_candidates",
      "meaning": "Map/pose evidence is available but not discriminative across candidates; defer rather than choosing by semantic or detector shortcuts."
    },
    {
      "tag": "candidate_geometry_missing",
      "meaning": "Required candidate_id, target_position, physical_viewpoint_position, or heading pose/depth/metadata fields are missing."
    },
    {
      "tag": "single_candidate_pool_geometry_only",
      "meaning": "A single-candidate pool is selected only because the candidate geometry is ready; this is diagnostic and not a goal-validity claim."
    },
    {
      "tag": "geometry_availability_bias",
      "meaning": "The selector may prefer candidates with more planned/rendered views rather than true task validity; task proxy join must diagnose this before formula revision."
    },
    {
      "tag": "semantic_shortcut_substituted_for_slam",
