  "selector_definition": {
    "policy_name": "SLAMOnlyRich_current",
    "selector_id": "candidate_map_pose_unique_ready_v1",
    "role": "candidate-specific map/pose selector for task-proxy measurement",
    "candidate_feature_row_rule": "Create one candidate feature row for each (source_name, episode_key, request_id, query, scene_key, candidate_id) observed in candidate-targeted frame rows from the source inventory.",
    "strict_candidate_map_pose_ready_rule": "A candidate is ready only if it has at least one candidate-targeted frame row, at least three pose/depth/metadata heading references, at least one projection-visible heading, at least one navmesh-snapped or navigable viewpoint, finite target_position, and finite physical_viewpoint_position.",
    "candidate_map_pose_score_rule": "Diagnostic score only: rank ready candidates by geometry completeness tuple [projection_visible_heading_rows, pose_heading_rows, unique_viewpoint_count, navmesh_ready_viewpoint_count, -mean_target_distance_from_viewpoint_m]. Do not use semantic score, detector score, source-top rank, local-context rank, correctness label, or task outcome.",
    "request_selector_rule": "If exactly one candidate in the request is strict_candidate_map_pose_ready, select that candidate and set terminal_commit_proxy true. If zero candidates are ready, defer with reason no_candidate_map_pose_ready. If multiple candidates are ready, defer with reason multiple_map_pose_ready_candidates. Ties or missing required fields defer.",
    "single_candidate_pool_rule": "A single-candidate request may be selected only if the candidate satisfies strict_candidate_map_pose_ready. Record single_candidate_pool_geometry_only as a diagnostic flag; it is not a paper claim.",
    "selector_missing_rule": "selector_missing is true only when candidate feature rows cannot be materialized for the request. Ambiguous or weak geometry must be represented as defer, not selector_missing.",
    "uses_gt_for_action": false,
    "candidate_specific_map_pose_required": true,
    "uses_reobservation_evidence": true
  },
