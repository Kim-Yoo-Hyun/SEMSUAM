  "design_principle": {
    "fact": "Paper-scale detector evidence supports all detector-eligible request rows, but every request is multi-strong saturated ambiguity.",
    "agent_inference": "The next active utility should collect local context evidence that can distinguish repeated or nearby same-category candidates, not choose the maximum detector score as a terminal goal."
  },
  "allowed_action_inputs": [
    "episode_key",
    "scene_key",
    "query",
    "rival_identity_request_id",
    "objective_action",
    "evidence_topology",
    "terminal_objective_risk",
    "expanded candidate ids and ranks",
    "candidate semantic score and support score",
