  "policy": {
    "name": "pair_graph_consistency_followup_v1",
    "purpose": "Audit whether residual pair evidence defines a consistent non-GT instance-arbitration branch outcome without using labels or shortcut graph-winner commits.",
    "non_gt_action_features": [
      "pair_graph loss counts",
      "pair_graph win counts",
      "lossless_pair_graph_candidate_count",
      "max_pair_win_candidate_ids",
      "unique_lossless_pair_graph_candidate_id",
      "ambiguous_pair_incident_counts",
      "pair residual failure classes",
      "candidate residual failure classes",
      "common-view overlap counts",
      "one-sided support counts",
      "rival leakage counts",
      "pair contradiction counts",
      "source-top and local-context support markers written before label join"
    ],
    "nonterminal_action_rule": [
      {
        "if": "lossless_pair_graph_candidate_count > 1",
        "then": "keep_multiple_lossless_pair_graph_candidates_unresolved"
      },
      {
        "if": "lossless_pair_graph_candidate_count == 1 and common_view_both_candidates_supported_count > 0",
        "then": "request_common_view_overlap_audit"
      },
      {
        "if": "pair_graph_winner exists but rival_leakage_count > 0 or pair_contradiction_count > 0",
        "then": "keep_graph_winner_nonterminal_due_residual_conflict"
      },
      {
        "if": "candidate has zero pair losses but also source_top_shortcut_rival_leakage or own_view_support_with_rival_leakage",
        "then": "block_lossless_candidate_shortcut"
      },
      {
        "if": "unique lossless candidate has no common-view overlap, no rival leakage, no pair contradiction, and at least one independent non-source-top support path",
        "then": "mark_pair_graph_consistency_promotable_for_later_terminal_contract_only"
      }
    ],
    "terminal_commit_allowed": false,
    "candidate_commit_allowed": false,
    "candidate_rejection_allowed": false,
    "uses_gt_for_action": false,
    "paper_claim_allowed": false
  },
