{
  "schema_version": "h001.contract.semantic_slam_proxy_comparison.v1",
  "date_checked": "2026-06-04",
  "status": "frozen_contract",
  "contract_name": "semantic_slam_proxy_comparison_v1",
  "purpose": "Freeze a P4-design proxy comparison contract for SemanticOnly, SLAMOnly, and SemanticSLAM after strict pose/map edge variants passed without relying on candidate-id overlap.",
  "source": {
    "strict_edge_contract": "configs/h001/manifests/h001_semantic_slam_strict_edge_variant_proxy_v1.json",
    "strict_edge_verify": "configs/h001/manifests/h001_semantic_slam_strict_edge_variant_proxy_v1.verify.json",
    "strict_edge_summary": "local_dataset/runs/h001_semantic_slam_strict_edge_variant_proxy_v1/semantic_slam_strict_edge_variant_proxy_summary.json",
    "strict_edge_variant_rows": "local_dataset/runs/h001_semantic_slam_strict_edge_variant_proxy_v1/semantic_slam_strict_edge_variant_proxy_rows.jsonl",
    "strict_edge_variant_summary_rows": "local_dataset/runs/h001_semantic_slam_strict_edge_variant_proxy_v1/semantic_slam_strict_edge_variant_proxy_summary_rows.jsonl",
    "source_audit_contract": "configs/h001/manifests/h001_semantic_slam_map_pose_consistency_probe_v1.json",
    "source_audit_summary": "local_dataset/runs/h001_semantic_slam_map_pose_consistency_probe_v1/semantic_slam_map_pose_consistency_probe_summary.json",
    "source_audit_pose_graph_rows": "local_dataset/runs/h001_semantic_slam_map_pose_consistency_probe_v1/semantic_slam_map_pose_graph_proxy_rows.jsonl",
    "source_audit_probe_request_rows": "local_dataset/runs/h001_semantic_slam_map_pose_consistency_probe_v1/semantic_slam_map_pose_probe_request_rows.jsonl"
  },
  "comparison_scope": {
    "stage": "P4-design",
    "comparison_name": "semantic_slam_proxy_comparison_v1",
    "request_group_count": 50,
    "join_key": [
      "source_name",
      "scene_key",
      "query",
      "request_id",
      "episode_key"
    ],
    "same_request_groups_required_for_all_policies": true,
    "canonical_pose_variant": "pose_spatial_or_loop",
    "context_pose_variant": "map_pose_context_no_candidate",
    "loop_variant": "pose_loop",
    "shortcut_diagnostic_variant": "candidate_overlap_only",
    "paper_claim_allowed": false,
    "step_4_5_promotion_satisfied": false
  },
  "policy_definitions": [
    {
      "policy_name": "NoReobserveReference",
      "role": "non_active_reference",
      "allowed_action_inputs": [
        "request group identity",
        "source artifact group",
        "pre-existing proxy rows"
      ],
      "forbidden_action_inputs": [
        "new viewpoint selection",
        "candidate correctness",
        "GT pose error",
        "ObjectNav success or wrong-goal labels"
      ],
      "utility_formula": "U = 0",
      "interpretation": "Reference row for comparing proxy deltas; not a navigation policy."
    },
    {
      "policy_name": "SemanticOnly",
      "role": "semantic_uncertainty_proxy",
      "allowed_action_inputs": [
        "semantic_uncertainty_family",
        "candidate_id_count",
        "candidate_set_rule_counts",
        "view_role_counts",
        "viewpoint_source_counts",
        "travel_cost_proxy_m"
      ],
      "forbidden_action_inputs": [
        "strict pose graph connectivity metrics",
        "candidate correctness",
        "GT pose error",
        "ObjectNav success or wrong-goal labels"
      ],
      "semantic_score_formula": "0.6 * semantic_family_weight + 0.4 * min(candidate_id_count / 10, 1)",
      "travel_penalty_formula": "0.1 * normalized_travel_cost_proxy",
      "utility_formula": "U_sem - travel_penalty",
      "interpretation": "Tests semantic uncertainty pressure without SLAM/map connectivity utility."
    },
    {
      "policy_name": "SLAMOnly",
      "role": "strict_pose_map_proxy",
      "allowed_action_inputs": [
        "pose_spatial_or_loop connected_component_count",
        "pose_spatial_or_loop largest_component_fraction",
        "pose_spatial_or_loop edge_count",
        "pose_loop edge_count",
        "map_pose_context_no_candidate edge_count",
        "travel_cost_proxy_m"
      ],
      "forbidden_action_inputs": [
        "semantic_uncertainty_family as a utility term",
        "candidate_id_overlap edges",
        "candidate correctness",
        "GT pose error",
        "ObjectNav success or wrong-goal labels"
      ],
      "slam_gap_formula": "0.5 * (1 - largest_component_fraction) + 0.3 * loop_missing_indicator + 0.2 * edge_sparsity_proxy",
      "travel_penalty_formula": "0.1 * normalized_travel_cost_proxy",
      "utility_formula": "U_slam - travel_penalty",
      "interpretation": "Tests whether strict pose/map proxy alone explains future map/pose-side utility."
    },
    {
      "policy_name": "SemanticSLAM",
      "role": "combined_semantic_pose_map_proxy",
      "allowed_action_inputs": [
        "all SemanticOnly allowed inputs",
        "all SLAMOnly allowed inputs"
      ],
      "forbidden_action_inputs": [
        "candidate_id_overlap edges as pose evidence",
        "candidate correctness",
        "GT pose error",
        "ObjectNav success or wrong-goal labels",
        "weights tuned on evaluation labels"
      ],
      "utility_formula": "0.5 * U_sem + 0.5 * U_slam - travel_penalty",
      "interpretation": "Tests complementarity at proxy-contract level; does not establish utility until implemented and verified."
    }
  ],
  "fixed_semantic_family_weights": {
    "instance_arbitration_defer_v1": 1.0,
    "partial_relation_depth_true_goal": 0.9,
    "missing_own_view_support_recheck": 0.8,
    "object_relation_goal_validity_confirmation": 0.8,
    "expanded_retrieval_source_pool": 0.7,
    "unknown_semantic_uncertainty_family": 0.5
  },
  "metric_contract": {
    "required_row_outputs": [
      "policy_name",
      "source_name",
      "scene_key",
      "query",
      "request_id",
      "episode_key",
