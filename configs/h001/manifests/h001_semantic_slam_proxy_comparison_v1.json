    ],
    "required_summary_outputs": [
      "policy_rows",
      "request_groups",
      "policy_count",
      "same_request_groups_gate",
      "policy_proxy_utility_stats",
      "canonical_proxy_ready_rate",
      "mean_canonical_edge_count",
      "mean_largest_component_fraction",
      "loop_edge_availability_rate",
      "mean_travel_penalty",
      "action_evidence_forbidden_key_count",
      "terminal_commit_rows",
      "candidate_commit_rows",
      "candidate_rejection_rows",
      "uses_gt_for_action",
      "paper_claim_allowed"
    ],
    "blocked_task_behavior_metrics": [
      "Success Rate",
      "SPL",
      "wrong_goal_visit",
      "wasted_path",
      "ATE/RPE",
      "map error",
      "semantic accuracy"
    ]
  },
  "gate_thresholds": {
