    "expected_request_groups": 50,
    "expected_comparison_rows": 200,
    "min_canonical_proxy_ready_rate": 0.9,
    "min_loop_proxy_ready_rate": 0.5,
    "max_action_evidence_forbidden_key_count": 0,
    "max_terminal_commit_rows": 0,
    "max_candidate_commit_rows": 0,
    "max_candidate_rejection_rows": 0,
    "requires_uses_gt_for_action": false
  },
  "required_future_outputs": {
    "comparison_rows": "semantic_slam_proxy_comparison_rows.jsonl",
    "policy_summary_rows": "semantic_slam_proxy_comparison_policy_summary_rows.jsonl",
    "summary": "semantic_slam_proxy_comparison_summary.json"
  },
  "next_implementation_target": {
