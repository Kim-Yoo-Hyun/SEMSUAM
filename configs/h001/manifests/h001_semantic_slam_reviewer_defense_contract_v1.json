    "shortcut_diagnostic_variant": "candidate_overlap_only",
    "paper_claim_allowed": false,
    "step_4_5_promotion_satisfied": false
  },
  "design_principle": {
    "fact": "The previous non-dominated proxy was rank-1 on 42/50 groups but strictly exceeded SemanticOnly on all 50/50 groups.",
    "agent_inference": "The next proxy must make any interaction gain over SemanticOnly depend on an independently measurable map/pose signal and must fail if the combined policy shadows SemanticOnly on every row again.",
    "paper_claim": "A reviewer-defense proxy can only become paper evidence after later task/map outcome validation; this contract alone is not a contribution claim."
  },
  "policy_definitions": [
    {
      "policy_name": "NoReobserveReference",
      "role": "non_active_reference",
      "utility_formula": "U = 0",
      "allowed_action_inputs": [
        "request group identity",
        "source artifact group",
        "pre-existing proxy rows"
      ],
      "forbidden_action_inputs": [
        "candidate correctness",
        "GT pose error",
        "ObjectNav success or wrong-goal labels"
      ]
    },
    {
      "policy_name": "SemanticOnly",
      "role": "semantic_component_reference",
      "semantic_score_formula": "0.6 * semantic_family_weight + 0.4 * min(candidate_id_count / 10, 1)",
      "travel_penalty_formula": "0.1 * normalized_travel_cost_proxy",
      "utility_formula": "U_sem = semantic_score - travel_penalty",
      "allowed_action_inputs": [
        "semantic_uncertainty_family",
        "candidate_id_count",
        "candidate_set_rule_counts",
        "view_role_counts",
        "viewpoint_source_counts",
        "travel_cost_proxy_m"
      ],
      "forbidden_action_inputs": [
        "strict pose graph connectivity metrics",
        "candidate correctness",
        "GT pose error",
        "ObjectNav success or wrong-goal labels"
      ]
    },
    {
      "policy_name": "SLAMOnlyRich",
      "role": "map_pose_component_reference",
      "fragmentation_formula": "clip((connected_component_count - 1) / 4, 0, 1)",
      "largest_component_gap_formula": "1 - largest_component_fraction",
      "loop_gap_formula": "1 if pose_loop edge_count == 0 else 0",
      "source_coverage_gap_formula": "1 - min(unique_viewpoint_count / 4, 1)",
      "context_gap_formula": "clip(1 - context_edge_count / max(canonical_edge_count, 1), 0, 1)",
      "map_pose_outcome_proxy_formula": "0.30 * fragmentation + 0.25 * largest_component_gap + 0.20 * loop_gap + 0.15 * source_coverage_gap + 0.10 * context_gap",
      "travel_penalty_formula": "0.1 * normalized_travel_cost_proxy",
      "utility_formula": "U_slam_rich = map_pose_outcome_proxy - travel_penalty",
      "allowed_action_inputs": [
        "pose_spatial_or_loop connected_component_count",
        "pose_spatial_or_loop largest_component_fraction",
        "pose_spatial_or_loop edge_count",
        "pose_loop edge_count",
        "map_pose_context_no_candidate edge_count",
        "unique_viewpoint_count",
        "frame_row_count",
        "travel_cost_proxy_m"
      ],
      "forbidden_action_inputs": [
        "semantic_uncertainty_family as a utility term",
        "candidate_id_overlap edges",
        "candidate correctness",
        "GT pose error",
        "ObjectNav success or wrong-goal labels"
      ]
    },
    {
      "policy_name": "SemanticSLAMInteractionGuarded",
      "role": "reviewer_defense_interaction_proxy",
      "semantic_score_formula": "0.6 * semantic_family_weight + 0.4 * min(candidate_id_count / 10, 1)",
      "map_pose_outcome_proxy_formula": "same as SLAMOnlyRich",
      "semantic_pressure_formula": "clip((semantic_score - 0.55) / 0.35, 0, 1)",
      "map_pose_pressure_formula": "clip(map_pose_outcome_proxy / 0.8, 0, 1)",
      "map_pose_explanation_gate_formula": "map_pose_pressure >= 0.25 and at least one of fragmentation, largest_component_gap, loop_gap, source_coverage_gap, context_gap is >= 0.25",
      "interaction_gain_formula": "0.30 * semantic_pressure * map_pose_pressure * map_pose_outcome_proxy",
      "non_shadowing_cap_formula": "if no task/map outcome validation is attached, U_guarded <= U_sem + 0.75 * max(0, U_slam_rich - U_sem) + interaction_gain_formula",
      "travel_penalty_formula": "0.1 * normalized_travel_cost_proxy",
      "utility_formula": "U_guarded = semantic_score - travel_penalty + interaction_gain_formula, then apply non_shadowing_cap_formula",
      "design_intent": "Interaction gain is allowed only when semantic pressure and independently measured map/pose pressure co-exist. The cap is a guard against semantic-first additive shadowing, not the main contribution.",
      "allowed_action_inputs": [
        "all SemanticOnly allowed inputs",
        "all SLAMOnlyRich allowed inputs",
        "semantic_pressure derived before evaluation labels",
        "map_pose_pressure derived before evaluation labels",
        "map_pose_explanation_gate derived before evaluation labels"
      ],
      "forbidden_action_inputs": [
        "candidate_id_overlap edges as pose evidence",
        "candidate correctness",
        "GT pose error",
        "ObjectNav success or wrong-goal labels",
        "weights tuned on evaluation labels",
        "post-hoc component winner labels",
        "unconditional positive bonus over SemanticOnly"
      ]
    }
  ],
  "forbidden_patterns": [
    {
      "pattern": "semantic_only_plus_nonnegative_bonus_on_every_row",
      "reason": "This reproduces the previous semantic-first shadowing failure."
    },
    {
      "pattern": "cap_only_contribution",
      "reason": "A cap is only a reviewer-defense guard and does not explain why SLAM/map evidence changes utility."
    },
    {
      "pattern": "component_max_shortcut",
      "reason": "Choosing the best component is a policy-selection shortcut, not complementarity."
    },
    {
      "pattern": "candidate_overlap_as_pose_evidence",
      "reason": "Candidate-id overlap is not independent SLAM/map evidence."
    },
    {
      "pattern": "label_tuned_weight_search",
      "reason": "Evaluation labels must not determine action-evidence weights."
    }
  ],
