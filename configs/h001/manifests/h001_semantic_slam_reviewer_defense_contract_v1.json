        "path": "direct_task_map_validation_of_current_additive_proxy",
        "reason": "The current additive proxy is already known to shadow SemanticOnly, so validating it directly would not isolate semantic-SLAM complementarity."
      }
    ]
  },
  "reviewer_defense_scope": {
    "stage": "P4-design",
    "comparison_name": "semantic_slam_reviewer_defense_v1",
    "request_group_count": 50,
    "join_key": [
      "source_name",
      "scene_key",
      "query",
      "request_id",
      "episode_key"
    ],
    "same_request_groups_required_for_all_policies": true,
