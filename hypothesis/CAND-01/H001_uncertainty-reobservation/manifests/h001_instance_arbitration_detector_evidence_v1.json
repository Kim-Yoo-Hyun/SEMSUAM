  "evidence_definitions": {
    "candidate_support_in_view": "For a view row, a candidate has at least one associated_to_candidate true association row for its candidate_id.",
    "candidate_inside_mask_support": "For a view row, a candidate has at least one association row with projected_pixel_inside_mask true for its candidate_id.",
    "candidate_depth_consistent_support": "For a view row, a candidate has at least one association row with depth_check_status equal to consistent for its candidate_id.",
    "rival_leakage": "A non-target selected candidate has candidate_support_in_view in a view intended to refresh or contrast the target candidate.",
    "source_top_shortcut_failure": "The source-top candidate has support but at least one rival also has support in source-top contrast, local-context contrast, or pair/common-or-standoff views.",
    "candidate_specific_support": "The candidate has own-view support and at least one contrast role with target support and no rival leakage.",
    "pair_resolved_in_favor_of_candidate": "Within a pair, one candidate has support in the pair/common-or-standoff evidence while the rival has no support or has explicit leakage/contradiction in the same evidence context.",
    "ambiguous_pair": "Both candidates have support, neither candidate has support, or support is missing only because of unavailable projection/detector evidence.",
    "promotable_branch_outcome": "Exactly one candidate in a request has candidate_specific_support, all pair contexts involving that candidate are resolved in its favor, and no shortcut evidence path is the only support source. This outcome only permits a later terminal-utility contract design; it does not permit a commit here."
  },
