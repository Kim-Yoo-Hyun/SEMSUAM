  "natural_proof_rule": {
    "post_hoc_fitting_forbidden": true,
    "rule": "Do not reshape metrics, thresholds, baselines, or labels to force the H001 hypothesis to look true. A promotable claim must follow naturally from a predeclared failure mechanism: goal-validity risk, viewpoint evidence gap, and map/pose consistency uncertainty should explain why active re-observation is needed and why the chosen method form follows.",
    "if_result_does_not_match_hypothesis": [
      "record_failure_mechanism",
      "reduce_claim_scope",
      "defer_terminal_utility",
      "define_new_hypothesis_only_after documenting the old failure"
    ],
    "not_allowed": [
      "change thresholds after inspecting held-out labels",
      "drop unfavorable baselines from the comparison",
      "reinterpret wrong-goal or wasted-path metrics after seeing results",
      "collapse map/pose degradation into an overall navigation score",
      "promote a detector, segmenter, or semantic-memory module combination as novelty without a failure-mechanism link"
    ]
  },
  "promotion_prerequisites": {
    "same_rows_required": true,
    "same_candidate_pool_required": true,
    "same_viewpoint_pool_required_when_applicable": true,
    "same_reobservation_budget_required": true,
    "same_travel_cost_accounting_required": true,
    "fixed_random_seed_required_for_random_baselines": true,
    "paired_metric_reporting_required": true,
    "non_gt_action_inputs_only": true,
    "evaluation_labels_joined_only_after_action_freeze": true,
    "commit_based_wrong_goal_metric_required": true,
    "near_candidate_pass_through_primary_wrong_goal_forbidden": true,
    "oracle_references_must_remain_diagnostic": true,
    "style_baselines_must_be_named_as_style_unless_exact_reproduction": true
  },
  "required_comparisons_before_terminal_utility_contract": {
