    ]
  },
  "diagnostic_gate": {
    "role": "Allows writing a later terminal-utility contract only if a fixed label-free branch produces sign-correct evidence on the same frozen split.",
    "minimum_rows": 50,
    "wrong_goal_direction": "lower_than_NoReobserveReference_and_SemanticOnly",
    "wasted_path_direction": "lower_than_NoReobserveReference_or_explained_by_nonterminal_defer_cost",
    "map_pose_direction": "nonnegative_map_pose_consistency_delta_vs_SemanticOnly_or_documented_no_degradation",
    "random_baseline_check": "RandomReobserve must not match or beat the proposed active selection under the same observation budget unless the claim is reduced to extra-observation utility.",
    "gt_leakage_check": "uses_gt_for_action_true_rows must be 0.",
    "terminal_shortcut_check": "The active observation utility itself must not be reused as a terminal goal score."
  },
  "paper_promotion_gate": {
    "role": "Allows paper-facing active re-observation claim only after diagnostic gate passes and a held-out or fresh split keeps the same direction without retuning.",
    "minimum_evaluation_rows": 100,
    "minimum_scene_count": 5,
    "wrong_goal_visit_reduction": {
      "vs_NoReobserveReference": {
        "absolute_percentage_point_min": 5,
        "relative_reduction_min": 0.2
      },
      "vs_SemanticOnly": {
        "must_be_non_worse": true,
        "preferred_absolute_percentage_point_min": 3
      },
      "vs_RandomReobserve": {
        "must_be_better": true,
        "if_not_better": "active_selection_novelty_blocked"
      }
    },
    "wasted_path_reduction": {
      "vs_NoReobserveReference": {
        "absolute_meter_min": 0.5,
        "relative_reduction_min": 0.15
      },
      "vs_SemanticOnly": {
        "must_be_non_worse": true
      },
      "total_path_cost_guard": {
        "mean_wasted_path_total_increase_absolute_meter_max": 0.5,
        "mean_wasted_path_total_increase_relative_max": 0.1
      }
    },
    "map_pose_non_degradation": {
      "map_pose_consistency_delta_vs_SemanticOnly": "mean_or_median_must_be_nonnegative",
      "pose_graph_connectivity_delta_vs_SemanticOnly": "must_not_decrease_unless_explained_by_valid_defer",
      "map_task_alignment_delta_vs_SemanticOnly": "must_not_decrease",
      "if_degraded": "navigation_only_claim_allowed_at_most_semantic_slam_claim_blocked"
    },
    "observation_budget_guard": {
      "mean_num_reobservations_max": 1.5,
      "same_budget_as_random_required": true,
      "travel_cost_accounted_in_primary_table": true
    },
    "held_out_requirement": {
      "fixed_split_before_run": true,
      "no_threshold_retuning_after_calibration": true,
      "one_fresh_or_scene_disjoint_validation_required_before_paper_claim": true
    }
  },
  "failure_interpretation": {
    "wrong_goal_reduced_but_map_pose_degrades": "Do not claim Semantic-SLAM utility; at most record a navigation-only diagnostic and revise the map/pose term.",
    "random_reobserve_matches_or_beats": "Active selection novelty is blocked; report that extra observation budget explains the effect.",
